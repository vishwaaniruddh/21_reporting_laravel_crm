APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Pipeline Configuration (Requirements: 6.1, 6.2, 6.3, 6.4)
# Batch size for sync operations (10000-50000)
PIPELINE_BATCH_SIZE=10000

# Sync schedule (cron expression) - default: every 15 minutes
PIPELINE_SYNC_SCHEDULE="*/15 * * * *"

# Enable/disable automatic sync
PIPELINE_SYNC_ENABLED=true

# Date-Partitioned Sync Configuration (Requirements: 5.1)
# Enable/disable date-partitioned sync (syncs to alerts_YYYY_MM_DD tables)
PIPELINE_PARTITIONED_SYNC_ENABLED=false

# Maximum number of batches to process per scheduled run
PIPELINE_PARTITIONED_SYNC_MAX_BATCHES=5

# Cleanup schedule (cron expression) - default: daily at 2 AM
PIPELINE_CLEANUP_SCHEDULE="0 2 * * *"

# Enable/disable automatic cleanup (DISABLED by default for safety)
# ⚠️ WARNING: Enabling cleanup will DELETE records from MySQL alerts table!
PIPELINE_CLEANUP_ENABLED=false

# Cleanup batch size (records per batch)
PIPELINE_CLEANUP_BATCH_SIZE=1000

# Retention period in days before cleanup
PIPELINE_RETENTION_DAYS=7

# Verification schedule (cron expression) - default: every 30 minutes
PIPELINE_VERIFY_SCHEDULE="*/30 * * * *"

# Enable/disable automatic verification
PIPELINE_VERIFY_ENABLED=true

# Job timeout in seconds
PIPELINE_JOB_TIMEOUT=3600

# Retry configuration
PIPELINE_MAX_RETRY_ATTEMPTS=5
PIPELINE_RETRY_INITIAL_DELAY=1
PIPELINE_RETRY_MAX_DELAY=30

# Alert thresholds
PIPELINE_WARNING_FAILURES=3
PIPELINE_CRITICAL_FAILURES=5
PIPELINE_MAX_SYNC_LAG=60

# Email notifications
PIPELINE_EMAIL_NOTIFICATIONS=false
PIPELINE_NOTIFICATION_EMAIL=

# Off-peak hours (24-hour format)
PIPELINE_OFF_PEAK_START=22
PIPELINE_OFF_PEAK_END=6
PIPELINE_PREFER_OFF_PEAK=true

# Allow runtime configuration changes via API
PIPELINE_ALLOW_RUNTIME_CONFIG=true
